# Copie ce fichier en .env et renseigne ta clé.
# Clé API Anthropic (obligatoire pour les fonctions IA)
ANTHROPIC_API_KEY=sk-ant-...

# Modèle utilisé pour les relances et la synthèse (optionnel)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Dossier de persistance. En prod Coolify : /app/.storage (volume monté).
STORAGE_DIR=/app/.storage
